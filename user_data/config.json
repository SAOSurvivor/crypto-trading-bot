{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "max_open_trades": 5,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "amount_reserve_percent": 0.05,
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": false,
  "trading_mode": "spot",
  "margin_mode": "",
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {"enabled": false, "bids_to_ask_delta": 1}
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "kucoin",
    "key": "${KUCOIN_API_KEY}",
    "secret": "${KUCOIN_API_SECRET}",
    "password": "${KUCOIN_API_PASSPHRASE}",
    "ccxt_config": {"enableRateLimit": true},
    "ccxt_async_config": {"enableRateLimit": true, "rateLimit": 200  },
    "pair_whitelist": [
      "BTC/USDT", "ETH/USDT", "BNB/USDT", "SOL/USDT", "ADA/USDT",
      "DOT/USDT", "LINK/USDT", "AVAX/USDT", "MATIC/USDT", "XRP/USDT"
    ],
    "pair_blacklist": [
      "KCS/USDT", "BNB/BTC", "*/BNB",
      ".*BULL/USDT", ".*BEAR/USDT", ".*UP/USDT", ".*DOWN/USDT"
    ]
  },
  "pairlists": [{"method": "StaticPairList"}],
  "telegram": {
    "enabled": false,
    "token": "${TELEGRAM_BOT_TOKEN}",
    "chat_id": "${TELEGRAM_CHAT_ID}",
    "notification_settings": {
      "status": "silent",
      "warning": "on",
      "startup": "on",
      "entry": "on",
      "entry_fill": "on",
      "entry_cancel": "silent",
      "exit": {"roi": "on", "emergency_exit": "on", "force_exit": "on",
                "exit_signal": "silent", "stoploss": "on",
                "stoploss_on_exchange": "on", "trailing_stop_loss": "on", "other": "on"},
      "exit_fill": "on",
      "exit_cancel": "on"
    }
  },
  "api_server": {
    "enabled": false,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "${API_JWT_SECRET}",
    "CORS_origins": [],
    "username": "${API_USERNAME}",
    "password": "${API_PASSWORD}"
  },
  "bot_name": "kucoin-freqtrade",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {"process_throttle_secs": 5},
  "strategy": "RSIStrategy",
  "strategy_path": "/freqtrade/user_data/strategies/",
  "db_url": "sqlite:////freqtrade/user_data/tradesv3.sqlite",
  "logfile": "/freqtrade/user_data/logs/freqtrade.log"
}
