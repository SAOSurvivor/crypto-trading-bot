# .env.example - Copy to .env and fill in values. NEVER commit .env

# KuCoin API Credentials (from https://www.kucoin.com/account/api)
KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_API_SECRET=your_kucoin_api_secret_here
KUCOIN_API_PASSPHRASE=your_kucoin_api_passphrase_here

# Strategy to run (default: RSIStrategy)
# Options: RSIStrategy, EMAStrategy, BollingerBandsStrategy, MACDStrategy,
#          SuperTrendStrategy, VolumeBreakoutStrategy, StochasticRSIStrategy,
#          CombinedSignalStrategy
STRATEGY=RSIStrategy

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# REST API
API_JWT_SECRET=change-this-to-a-random-string
API_USERNAME=admin
API_PASSWORD=change-this-password
